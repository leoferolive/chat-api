    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Quantis e média da duração de /chat/stream no intervalo. Calculado sobre todo o intervalo (não janela de 5m) porque o volume é baixo e a taxa/5m fica vazia.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 10}]}
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 18},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (increase(chat_api_chat_duration_seconds_bucket{namespace=~\"$namespace\"}[$__range])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (increase(chat_api_chat_duration_seconds_bucket{namespace=~\"$namespace\"}[$__range])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (increase(chat_api_chat_duration_seconds_bucket{namespace=~\"$namespace\"}[$__range])))",
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "expr": "sum(increase(chat_api_chat_duration_seconds_sum{namespace=~\"$namespace\"}[$__range])) / sum(increase(chat_api_chat_duration_seconds_count{namespace=~\"$namespace\"}[$__range]))",
          "legendFormat": "média",
          "refId": "D"
        }
      ],
      "title": "Latência no intervalo (p50 / p95 / p99 / média)",
      "type": "stat"
    },
