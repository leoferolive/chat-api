      "targets": [
        {"expr": "sum(chat_api_daily_calls{namespace=~\"$namespace\"})", "refId": "A"}
      ],
      "title": "Chamadas LLM hoje (de 500)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
