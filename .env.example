# Runtime environment
ENV=dev
ALLOWED_ORIGINS=http://localhost:5173,https://leoferolive.com.br

# Wiki & DB locations
WIKI_DIR=./wiki-fixture
DB_PATH=./data/chat.sqlite

# Cloudflare Turnstile (server-side verify + site key for the frontend)
TURNSTILE_SECRET=replace-me-turnstile-secret
TURNSTILE_SITE_KEY=replace-me-turnstile-site-key
# Set to "true" to bypass turnstile in dev environments
TURNSTILE_DISABLED=true

# Session JWT (HS256). Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-random-hex-32-bytes
SESSION_TTL_SECONDS=3600

# Salt for hashing client IPs before storage
IP_HASH_SALT=replace-me-ip-hash-salt

# Rate limiting
RATE_LIMIT_PER_IP=10/5minutes

# Daily LLM call kill-switch
DAILY_LLM_CALL_LIMIT=500

# Provider list (comma separated, in order of fallback). Use LiteLLM model strings.
LLM_PROVIDERS=gemini/gemini-2.5-flash,openrouter/anthropic/claude-haiku-4.5

# Provider API keys (LiteLLM picks them up from env)
GEMINI_API_KEY=replace-me
OPENROUTER_API_KEY=replace-me

# Retrieval tuning
RETRIEVER_TOP_N=5

# Wiki cache invalidation polling (seconds, 0 to disable)
WIKI_POLL_SECONDS=60
